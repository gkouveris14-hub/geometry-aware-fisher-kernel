// PC mask from the thesis (pc_mask_visualization)
digraph {
	dpi=300 rankdir=LR size="12,10"
	age [label=age fillcolor=lightblue shape=ellipse style=filled]
	trestbps [label=trestbps fillcolor=lightblue shape=ellipse style=filled]
	chol [label=chol fillcolor=lightblue shape=ellipse style=filled]
	thalch [label=thalch fillcolor=lightblue shape=ellipse style=filled]
	oldpeak [label=oldpeak fillcolor=lightblue shape=ellipse style=filled]
	sex [label=sex fillcolor=lightblue shape=ellipse style=filled]
	fbs [label=fbs fillcolor=lightblue shape=ellipse style=filled]
	exang [label=exang fillcolor=lightblue shape=ellipse style=filled]
	slope [label=slope fillcolor=lightblue shape=ellipse style=filled]
	age -> thalch [color=blue penwidth=2]
	chol -> thalch [color=blue penwidth=2]
	exang -> thalch [color=blue penwidth=2]
	slope -> thalch [color=blue penwidth=2]
	trestbps -> oldpeak [color=blue penwidth=2]
	chol -> oldpeak [color=blue penwidth=2]
	exang -> oldpeak [color=blue penwidth=2]
	slope -> oldpeak [color=blue penwidth=2]
	age -> fbs [color=blue penwidth=2]
	trestbps -> fbs [color=blue penwidth=2]
	chol -> fbs [color=blue penwidth=2]
	trestbps -> exang [color=blue penwidth=2]
	sex -> exang [color=blue penwidth=2]
	thalch -> slope [label="↔" color=blue penwidth=2]
	oldpeak -> slope [label="↔" color=blue penwidth=2]
	exang -> slope [color=blue penwidth=2]
	trestbps -> age [color=red penwidth=2 style=dashed]
	thalch -> age [color=red penwidth=2 style=dashed]
	fbs -> age [color=red penwidth=2 style=dashed]
	chol -> sex [color=red penwidth=2 style=dashed]
	exang -> sex [color=red penwidth=2 style=dashed]
	label="PC Mask Visualization\nBlue = Kept in Final Mask | Red Dashed = Removed by Domain Knowledge (age & sex)"
}
